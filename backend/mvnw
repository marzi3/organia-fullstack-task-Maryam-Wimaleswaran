#!/bin/sh
# Maven Wrapper script
# This script downloads and runs the Maven wrapper if not already present

set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
    MAVEN_DIST_URL=$(grep 'distributionUrl' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
fi

MAVEN_HOME="${MAVEN_HOME:-$HOME/.m2/wrapper/dists/apache-maven-3.9.6}"

if [ ! -d "$MAVEN_HOME" ]; then
    mkdir -p "$MAVEN_HOME"
    echo "Downloading Maven..."
    curl -sL "$MAVEN_DIST_URL" -o /tmp/maven.zip
    unzip -qo /tmp/maven.zip -d "$MAVEN_HOME/.."
    rm -f /tmp/maven.zip
fi

MAVEN_BIN=$(find "$MAVEN_HOME" -name "mvn" -path "*/bin/mvn" 2>/dev/null | head -1)
if [ -z "$MAVEN_BIN" ]; then
    MAVEN_BIN=$(find "$(dirname "$MAVEN_HOME")" -name "mvn" -path "*/bin/mvn" 2>/dev/null | head -1)
fi

if [ -z "$MAVEN_BIN" ]; then
    echo "Error: Could not find Maven binary" >&2
    exit 1
fi

exec "$MAVEN_BIN" "$@"
